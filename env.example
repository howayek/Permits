## Copy to .env.local and fill in values.
## Get these from Supabase Dashboard → Project Settings → API

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key
VITE_SUPABASE_ANON_KEY=

# Optional: override Supabase Edge Functions URL for local dev
# (requires `supabase start`)
# VITE_SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1

# Optional: only needed if you use code paths that expect VITE_SUPABASE_PUBLISHABLE_KEY
# VITE_SUPABASE_PUBLISHABLE_KEY=

